```jsx
import { useMemo, useState } from "react";

// Fresh Market page body — small-quantity, ready-now buying with add-to-cart.
// NOT wholesale (no large quantities / make-offer here).

const HERO_BADGES = [
  { icon: "🌿", label: "Ready now", kh: "មានរួចរាល់" },
  { icon: "✅", label: "Verified farmers", kh: "កសិករបានផ្ទៀងផ្ទាត់" },
  { icon: "⚖️", label: "Fair price", kh: "តម្លៃសមរម្យ" },
  { icon: "🚚", label: "Same-day / next-day supply", kh: "ផ្គត់ផ្គង់ភ្លាមៗ" },
];

const CATEGORIES = [
  { key: "all", label: "All", kh: "ទាំងអស់", count: 56 },
  { key: "fruits", label: "Fruits", kh: "ផ្លែឈើ", count: 21 },
  { key: "vegetables", label: "Vegetables", kh: "បន្លែ", count: 18 },
  { key: "rice", label: "Rice", kh: "អង្ករ", count: 9 },
  { key: "herbs", label: "Herbs", kh: "គ្រឿងទេស", count: 6 },
  { key: "organic", label: "Organic", kh: "សរីរាង្គ", count: 4 },
  { key: "near", label: "Near me", kh: "ជិតខ្ញុំ", count: 12 },
];

const SORT_OPTIONS = [
  { key: "popular", label: "Popular" },
  { key: "price", label: "Lowest price" },
  { key: "rating", label: "Highest rating" },
  { key: "near", label: "Near me" },
];

// kg products use the standard small-quantity steps; coconut is sold "each".
const KG_STEPS = [1, 2, 3, 5, 6];
const EACH_STEPS = [1, 3, 6];

const PRODUCTS = [
  { id: "mango", emoji: "🥭", kh: "ស្វាយកែវរមៀត", en: "Keo Romeat Mango", farmer: "Sok Chan Farm", province: "Kampong Speu", priceValue: 500, priceLabel: "500៛", unit: "kg", today: "80kg today", badge: "Grade A", rating: 4.8, categories: ["fruits", "near"], c1: "#ffe2a8", c2: "#f6b24a" },
  { id: "tomato", emoji: "🍅", kh: "ប៉េងប៉ោះ", en: "Tomato", farmer: "Dara Farm", province: "Takeo", priceValue: 1200, priceLabel: "1,200៛", unit: "kg", today: "45kg today", badge: "Fresh", rating: 4.7, categories: ["vegetables"], c1: "#ffd0c4", c2: "#e3604a" },
  { id: "cucumber", emoji: "🥒", kh: "ត្រសក់", en: "Cucumber", farmer: "Maly Farm", province: "Kandal", priceValue: 900, priceLabel: "900៛", unit: "kg", today: "60kg today", badge: "Ready now", rating: 4.6, categories: ["vegetables", "near"], c1: "#d7f0b8", c2: "#7fb24a" },
  { id: "banana", emoji: "🍌", kh: "ចេក", en: "Banana", farmer: "Lina Organic Farm", province: "Kampong Cham", priceValue: 1000, priceLabel: "1,000៛", unit: "kg", today: "70kg today", badge: "Organic", rating: 4.9, categories: ["fruits", "organic"], c1: "#fff0b0", c2: "#ecc23a" },
  { id: "morning-glory", emoji: "🥬", kh: "ត្រកួន", en: "Morning Glory", farmer: "Vireak Farm", province: "Prey Veng", priceValue: 800, priceLabel: "800៛", unit: "kg", today: "35kg today", badge: "Fresh", rating: 4.7, categories: ["vegetables"], c1: "#c9eab0", c2: "#5c9b61" },
  { id: "coconut", emoji: "🥥", kh: "ដូងខ្ចី", en: "Young Coconut", farmer: "Chanthy Farm", province: "Kampot", priceValue: 1500, priceLabel: "1,500៛", unit: "each", today: "50 today", badge: "Popular", rating: 4.8, categories: ["fruits", "near"], c1: "#e7f3d8", c2: "#a9c98a" },
];

const POPULAR_FRUITS = [
  { emoji: "🥭", kh: "ស្វាយ", en: "Mango", price: "500៛/kg" },
  { emoji: "🍌", kh: "ចេក", en: "Banana", price: "1,000៛/kg" },
  { emoji: "🥥", kh: "ដូងខ្ចី", en: "Young Coconut", price: "1,500៛/each" },
  { emoji: "🍈", kh: "ឪឡឹក", en: "Melon", price: "1,800៛/kg" },
];

const VEG_READY = [
  { emoji: "🍅", kh: "ប៉េងប៉ោះ", en: "Tomato", price: "1,200៛/kg" },
  { emoji: "🥒", kh: "ត្រសក់", en: "Cucumber", price: "900៛/kg" },
  { emoji: "🥬", kh: "ត្រកួន", en: "Morning Glory", price: "800៛/kg" },
  { emoji: "🌶️", kh: "ម្ទេស", en: "Chili", price: "2,400៛/kg" },
];

const FARMERS = [
  { initials: "SC", name: "Sok Chan Farm", province: "Kampong Speu", rating: 4.8 },
  { initials: "LO", name: "Lina Organic Farm", province: "Kampong Cham", rating: 4.9 },
  { initials: "DF", name: "Dara Farm", province: "Takeo", rating: 4.7 },
  { initials: "MF", name: "Maly Farm", province: "Kandal", rating: 4.6 },
];

function stepsFor(product) {
  return product.unit === "each" ? EACH_STEPS : KG_STEPS;
}

function ProductCard({ product }) {
  const steps = stepsFor(product);
  const [stepIndex, setStepIndex] = useState(0);
  const [added, setAdded] = useState(false);
  const qty = steps[stepIndex];

  function changeQty(delta) {
    setStepIndex((i) => Math.min(steps.length - 1, Math.max(0, i + delta)));
  }
  function addToCart() {
    setAdded(true);
    window.setTimeout(() => setAdded(false), 1600);
  }

  const unitWord = product.unit === "each" ? "each" : "kg";

  return (
    <article className="fm-card">
      <div className="fm-card-img" style={{ "--c1": product.c1, "--c2": product.c2 }}>
        <span className="fm-emoji" aria-hidden="true">{product.emoji}</span>
        <span className="fm-badge">{product.badge}</span>
        <span className="fm-today">{product.today}</span>
      </div>
      <div className="fm-card-body">
        <strong className="fm-kh">{product.kh}</strong>
        <span className="fm-en">{product.en}</span>
        <span className="fm-farm">{product.farmer} · {product.province}</span>
        <div className="fm-rate-row">
          <span className="fm-rating" aria-label={`Rated ${product.rating} out of 5`}>★ {product.rating.toFixed(1)}</span>
          <span className="fm-price"><strong>{product.priceLabel}</strong>/{unitWord}</span>
        </div>
        <div className="fm-qty" role="group" aria-label={`Quantity for ${product.en}`}>
          <button type="button" className="fm-qty-btn" onClick={() => changeQty(-1)} disabled={stepIndex === 0} aria-label="Decrease quantity">−</button>
          <span className="fm-qty-value">{qty} {unitWord}</span>
          <button type="button" className="fm-qty-btn" onClick={() => changeQty(1)} disabled={stepIndex === steps.length - 1} aria-label="Increase quantity">+</button>
        </div>
        <button type="button" className={`fm-add ${added ? "is-added" : ""}`} onClick={addToCart}>
          {added ? "✓ Added to cart" : "Add to cart"}
        </button>
      </div>
    </article>
  );
}

function MiniCard({ item }) {
  return (
    <article className="fm-mini">
      <div className="fm-mini-img" aria-hidden="true">{item.emoji}</div>
      <div className="fm-mini-body">
        <strong>{item.kh}</strong>
        <span>{item.en}</span>
        <span className="fm-mini-price">{item.price}</span>
      </div>
    </article>
  );
}

export default function FreshMarket() {
  const [activeCategory, setActiveCategory] = useState("all");
  const [sort, setSort] = useState("popular");

  const visibleProducts = useMemo(() => {
    let list = activeCategory === "all" ? PRODUCTS : PRODUCTS.filter((p) => p.categories.includes(activeCategory));
    list = [...list];
    if (sort === "price") list.sort((a, b) => a.priceValue - b.priceValue);
    else if (sort === "rating") list.sort((a, b) => b.rating - a.rating);
    return list;
  }, [activeCategory, sort]);

  return (
    <div className="fresh-market">
      <section className="fm-hero" id="top">
        <div className="fm-hero-copy">
          <span className="fm-hero-kicker">ផ្សារ​ស្រស់ · Fresh Market</span>
          <h1>Fresh Market</h1>
          <p>Ready-now crops from Cambodian farmers, available in small quantities for daily buyers.</p>
          <ul className="fm-hero-badges">
            {HERO_BADGES.map((b) => (
              <li key={b.label}>
                <span className="fm-hero-badge-icon" aria-hidden="true">{b.icon}</span>
                <span className="fm-hero-badge-text"><strong>{b.label}</strong><em>{b.kh}</em></span>
              </li>
            ))}
          </ul>
        </div>
        <div className="fm-hero-visual" aria-label="Fresh produce">
          <div className="fm-hero-basket">
            <span>🥭</span><span>🍅</span><span>🥬</span><span>🍌</span><span>🥒</span><span>🥥</span>
            <span className="fm-hero-basket-base" aria-hidden="true">🧺</span>
          </div>
        </div>
      </section>

      <section className="fm-shop page-section">
        <aside className="fm-sidebar" aria-label="Filter products">
          <h2 className="fm-sidebar-title">Categories <span>ប្រភេទ</span></h2>
          <ul className="fm-cat-list">
            {CATEGORIES.map((c) => (
              <li key={c.key}>
                <button type="button" className={activeCategory === c.key ? "is-active" : ""} onClick={() => setActiveCategory(c.key)}>
                  <span className="fm-cat-name">{c.kh} <em>{c.label}</em></span>
                  <span className="fm-cat-count">{c.count}</span>
                </button>
              </li>
            ))}
          </ul>
          <div className="fm-price-filter">
            <label htmlFor="fm-price">Price (៛/kg)</label>
            <input id="fm-price" type="range" min="500" max="5000" defaultValue="5000" step="100" />
            <div className="fm-price-scale"><span>500៛</span><span>5,000៛+</span></div>
          </div>
          <button type="button" className="button button-secondary fm-apply">Apply filters</button>
        </aside>

        <div className="fm-main">
          <div className="fm-toolbar">
            <div className="fm-chips" role="tablist" aria-label="Categories">
              {CATEGORIES.map((c) => (
                <button type="button" key={c.key} role="tab" aria-selected={activeCategory === c.key}
                  className={`fm-chip ${activeCategory === c.key ? "is-active" : ""}`} onClick={() => setActiveCategory(c.key)}>
                  {c.label}
                </button>
              ))}
            </div>
            <label className="fm-sort">
              <span>Sort by</span>
              <select value={sort} onChange={(e) => setSort(e.target.value)}>
                {SORT_OPTIONS.map((o) => (<option key={o.key} value={o.key}>{o.label}</option>))}
              </select>
            </label>
          </div>

          <div className="fm-row-head">
            <h2>Fresh Today <span>ស្រស់​ថ្ងៃនេះ</span></h2>
            <a className="fm-see-all" href="#/search">See all →</a>
          </div>

          {visibleProducts.length > 0 ? (
            <div className="fm-grid">{visibleProducts.map((p) => (<ProductCard key={p.id} product={p} />))}</div>
          ) : (
            <p className="fm-empty">No ready-now crops in this category yet.</p>
          )}
        </div>
      </section>

      <section className="fm-extra page-section">
        <div className="fm-row-head"><h2>Popular Fruits <span>ផ្លែឈើពេញនិយម</span></h2><a className="fm-see-all" href="#/search">See all →</a></div>
        <div className="fm-mini-grid">{POPULAR_FRUITS.map((item) => <MiniCard key={item.en} item={item} />)}</div>

        <div className="fm-row-head"><h2>Vegetables Ready Now <span>បន្លែ​រួចរាល់</span></h2><a className="fm-see-all" href="#/search">See all →</a></div>
        <div className="fm-mini-grid">{VEG_READY.map((item) => <MiniCard key={item.en} item={item} />)}</div>

        <div className="fm-row-head"><h2>Recommended Farmers <span>កសិករ​ណែនាំ</span></h2><a className="fm-see-all" href="#/search">See all →</a></div>
        <div className="fm-mini-grid">
          {FARMERS.map((f) => (
            <article className="fm-farmer" key={f.name}>
              <span className="fm-farmer-avatar" aria-hidden="true">{f.initials}</span>
              <div className="fm-farmer-body">
                <strong>{f.name}</strong><span>{f.province}</span><span className="fm-rating">★ {f.rating.toFixed(1)}</span>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  );
}
```

