.fm-hero-kicker { color: var(--green-700); font-weight: 900; letter-spacing: .12em; text-transform: uppercase; font-size: .78rem; }
.fm-hero h1 { color: var(--green-900); font-size: clamp(2.4rem, 5vw, 4rem); margin: 10px 0 12px; }
.fm-hero p { color: var(--muted); font-size: clamp(1rem, 1.4vw, 1.18rem); max-width: 46ch; line-height: 1.6; }
.fm-hero-badges { list-style: none; display: flex; flex-wrap: wrap; gap: 12px; padding: 0; margin: 26px 0 0; }
.fm-hero-badges li { display: inline-flex; align-items: center; gap: 10px; background: var(--white); border: 1px solid var(--line); border-radius: 14px; padding: 10px 14px; box-shadow: var(--shadow-soft); }
.fm-hero-badge-icon { font-size: 1.2rem; }
.fm-hero-badge-text strong { display: block; color: var(--green-900); font-size: .86rem; }
.fm-hero-badge-text em { font-style: normal; color: var(--muted); font-size: .72rem; }
.fm-hero-visual { display: flex; justify-content: center; }
.fm-hero-basket {
  position: relative; width: min(380px, 80vw); aspect-ratio: 1; border-radius: 28px;
  background: radial-gradient(circle at 50% 40%, #d6efc0, #a9c98a);
  display: grid; grid-template-columns: repeat(3, 1fr); place-items: center; gap: 6px;
  box-shadow: var(--shadow-card); font-size: clamp(2.4rem, 6vw, 3.6rem); padding: 28px;
}
.fm-hero-basket-base { position: absolute; bottom: -6px; left: 50%; transform: translateX(-50%); font-size: clamp(4rem, 12vw, 7rem); }

.fm-shop { display: grid; grid-template-columns: 250px 1fr; gap: 32px; align-items: start; padding-top: clamp(36px, 5vw, 64px); }
.fm-sidebar { position: sticky; top: 96px; background: var(--white); border: 1px solid var(--line); border-radius: 20px; padding: 20px; box-shadow: var(--shadow-soft); }
.fm-sidebar-title { font-size: 1rem; color: var(--green-900); margin: 0 0 14px; }
.fm-sidebar-title span { color: var(--muted); font-weight: 600; font-size: .85rem; }
.fm-cat-list { list-style: none; padding: 0; margin: 0 0 18px; display: grid; gap: 4px; }
.fm-cat-list button { width: 100%; display: flex; justify-content: space-between; align-items: center; gap: 8px; padding: 9px 12px; border: 0; background: transparent; border-radius: 12px; color: var(--ink); transition: background .2s; }
.fm-cat-list button:hover { background: var(--cream-200); }
.fm-cat-list button.is-active { background: var(--green-900); color: var(--white); }
.fm-cat-name em { font-style: normal; color: inherit; opacity: .7; font-size: .82rem; margin-left: 4px; }
.fm-cat-count { font-size: .76rem; opacity: .7; }
.fm-price-filter label { display: block; font-weight: 800; color: var(--green-900); font-size: .85rem; margin-bottom: 8px; }
.fm-price-filter input[type="range"] { width: 100%; accent-color: var(--green-600); }
.fm-price-scale { display: flex; justify-content: space-between; color: var(--muted); font-size: .74rem; margin-top: 4px; }
.fm-apply { width: 100%; margin-top: 16px; min-height: 44px; }

.fm-toolbar { display: flex; flex-wrap: wrap; gap: 14px; justify-content: space-between; align-items: center; margin-bottom: 22px; }
.fm-chips { display: flex; flex-wrap: wrap; gap: 8px; }
.fm-chip { border: 1px solid var(--line); background: var(--white); color: var(--green-700); border-radius: 999px; padding: 8px 16px; font-weight: 700; font-size: .85rem; transition: all .2s; }
.fm-chip:hover { border-color: var(--green-500); }
.fm-chip.is-active { background: var(--green-900); border-color: var(--green-900); color: var(--white); }
.fm-sort { display: inline-flex; align-items: center; gap: 8px; color: var(--muted); font-size: .85rem; font-weight: 700; }
.fm-sort select { border: 1px solid var(--line); border-radius: 12px; padding: 8px 12px; background: var(--white); color: var(--green-900); font-weight: 700; }

.fm-row-head { display: flex; justify-content: space-between; align-items: baseline; margin: 8px 0 16px; }
.fm-row-head h2 { color: var(--green-900); font-size: clamp(1.3rem, 2.4vw, 1.7rem); margin: 0; }
.fm-row-head h2 span { color: var(--muted); font-weight: 600; font-size: .9rem; margin-left: 6px; }
.fm-see-all { color: var(--green-700); font-weight: 800; font-size: .85rem; }
.fm-see-all:hover { color: var(--green-900); }
.fm-empty { color: var(--muted); padding: 30px 0; }

.fm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; }
.fm-card { background: var(--white); border: 1px solid var(--line); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow-soft); transition: transform .28s var(--ease), box-shadow .28s var(--ease); display: flex; flex-direction: column; }
.fm-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-card); }
.fm-card-img { position: relative; aspect-ratio: 16/11; background: linear-gradient(150deg, var(--c1, #ffe2a8), var(--c2, #f6b24a)); display: flex; align-items: center; justify-content: center; }
.fm-emoji { font-size: clamp(3rem, 7vw, 4.4rem); filter: drop-shadow(0 6px 10px rgba(0,0,0,.18)); }
.fm-badge { position: absolute; top: 10px; left: 10px; background: rgba(255,255,255,.92); color: var(--green-900); font-weight: 800; font-size: .72rem; padding: 4px 10px; border-radius: 999px; }
.fm-today { position: absolute; bottom: 10px; right: 10px; background: var(--green-900); color: var(--white); font-weight: 700; font-size: .72rem; padding: 4px 10px; border-radius: 999px; }
.fm-card-body { padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 4px; flex: 1; }
.fm-kh { color: var(--green-900); font-size: 1.02rem; }
.fm-en { color: var(--ink); font-size: .86rem; }
.fm-farm { color: var(--muted); font-size: .78rem; }
.fm-rate-row { display: flex; justify-content: space-between; align-items: center; margin: 6px 0 4px; }
.fm-rating { color: var(--gold); font-weight: 800; font-size: .82rem; }
.fm-price strong { color: var(--green-900); font-size: 1.05rem; }
.fm-price { color: var(--muted); font-size: .8rem; }
.fm-qty { display: flex; align-items: center; justify-content: space-between; border: 1px solid var(--line); border-radius: 12px; padding: 4px; margin: 8px 0; }
.fm-qty-btn { width: 32px; height: 32px; border: 0; border-radius: 9px; background: var(--cream-200); color: var(--green-900); font-size: 1.1rem; font-weight: 800; line-height: 1; }
.fm-qty-btn:hover:not(:disabled) { background: var(--green-300); }
.fm-qty-btn:disabled { opacity: .4; cursor: not-allowed; }
.fm-qty-value { font-weight: 800; color: var(--green-900); font-size: .9rem; }
.fm-add { width: 100%; min-height: 44px; border: 0; border-radius: 12px; background: linear-gradient(180deg, var(--green-600), var(--green-700)); color: var(--white); font-weight: 800; transition: background .25s, transform .15s; margin-top: auto; }
.fm-add:hover { transform: translateY(-1px); }
.fm-add.is-added { background: var(--green-900); }

.fm-extra { display: block; }
.fm-mini-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px; margin-bottom: 36px; }
.fm-mini, .fm-farmer { background: var(--white); border: 1px solid var(--line); border-radius: 16px; box-shadow: var(--shadow-soft); transition: transform .25s var(--ease); }
.fm-mini:hover, .fm-farmer:hover { transform: translateY(-4px); }
.fm-mini { display: flex; align-items: center; gap: 12px; padding: 12px; }
.fm-mini-img { font-size: 2rem; width: 54px; height: 54px; display: flex; align-items: center; justify-content: center; background: var(--cream-200); border-radius: 12px; }
.fm-mini-body { display: flex; flex-direction: column; }
.fm-mini-body strong { color: var(--green-900); font-size: .92rem; }
.fm-mini-body span { color: var(--ink); font-size: .78rem; }
.fm-mini-price { color: var(--green-700) !important; font-weight: 800; }
.fm-farmer { display: flex; align-items: center; gap: 12px; padding: 14px; }
.fm-farmer-avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(150deg, var(--green-500), var(--green-700)); color: var(--white); display: flex; align-items: center; justify-content: center; font-weight: 800; }
.fm-farmer-body { display: flex; flex-direction: column; }
.fm-farmer-body strong { color: var(--green-900); font-size: .9rem; }
.fm-farmer-body span { color: var(--muted); font-size: .78rem; }

@media (max-width: 900px) {
  .fm-hero { grid-template-columns: 1fr; }
  .fm-shop { grid-template-columns: 1fr; }
  .fm-sidebar { display: none; }            /* sidebar collapses; top chips remain on mobile */
  .fm-chips { overflow-x: auto; flex-wrap: nowrap; padding-bottom: 4px; -webkit-overflow-scrolling: touch; }
  .fm-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }  /* mobile: 2 columns */
}
```

